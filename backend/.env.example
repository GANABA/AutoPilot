# ── Identité de l'agence ──────────────────────────────────────────────────────
AGENCY_NAME="Agence ImmoPlus"
AGENCY_GREETING="Bonjour, bienvenue chez ImmoPlus !"
AGENCY_BRAND_VOICE="professionnel et chaleureux"
AGENCY_ESCALATION_EMAIL="contact@immoplus.fr"
AGENCY_WORKING_HOURS_START="09:00"
AGENCY_WORKING_HOURS_END="19:00"
WIDGET_TOKEN="tok_changez_moi_en_production"

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_COMPLEX_MODEL=gpt-4o
LLM_SIMPLE_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Base de données (Neon en prod, localhost en dev) ─────────────────────────
DATABASE_URL=postgresql://autopilot:autopilot@localhost:5432/autopilot
# Production Neon : postgresql://user:pass@ep-xxx.neon.tech/autopilot?sslmode=require

# ── Redis (Upstash en prod, localhost en dev) ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Production Upstash : rediss://default:xxx@apn-xxx.upstash.io:6380

# ── Stockage fichiers (Cloudflare R2) ─────────────────────────────────────────
CLOUDFLARE_R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=autopilot-docs

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=changez_moi_avec_openssl_rand_hex_32
ADMIN_EMAIL=admin@immoplus.fr
ADMIN_PASSWORD=MotDePasseSecurise123!

# ── Intégrations (ajoutées au fur et à mesure des semaines) ───────────────────
# RESEND_API_KEY=re_...
# VAPI_API_KEY=...
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+33...
# GOOGLE_CALENDAR_CREDENTIALS=./credentials.json

# ── App ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
DEBUG=true
